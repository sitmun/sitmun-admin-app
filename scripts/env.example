# Environment Configuration Template for SITMUN Admin App
# Copy this file to .env and fill in the values
# Note: .env files should NOT be committed to version control

# GitHub Pages Deployment
# Required for deployment scripts
GITHUB_API_KEY=your_github_token_here
USERNAME=your_github_username

# Build Configuration
# Base href for GitHub Pages deployment
BASE_HREF=https://sitmun.github.io/admin-app/

# E2E Testing Configuration
# API URL for test deployment (optional, will be extracted from environment file if not set)
E2E_API_URL=https://sitmun-backend-core.herokuapp.com
# Number of retry attempts when checking API availability
E2E_RETRY_COUNT=10
# Delay between retries (in seconds)
E2E_RETRY_DELAY=10

# CI/CD Environment Variables
# These are automatically set in GitHub Actions, but can be set locally for testing
GITHUB_WORKSPACE=${PWD}
CI=false
